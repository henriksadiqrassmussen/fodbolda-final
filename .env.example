# Railway sætter PORT automatisk. Lokalt kan du bruge 8080.
PORT=8080

# Railway PostgreSQL giver dig DATABASE_URL automatisk, når du tilføjer PostgreSQL plugin/service.
DATABASE_URL=postgresql://user:password@host:5432/database

# TheSportsDB gratis testnøgle er ofte 3. Brug din egen nøgle hvis du har premium.
THESPORTSDB_API_KEY=123

# Sæt false hvis backend ikke skal opdatere automatisk hver time.
AUTO_UPDATE_ENABLED=true

# CORS kan begrænses senere til din frontend/domæne.
CORS_ORIGIN=*

# På Railway kan SSL normalt være true/default.
# Lokalt kan du evt. sætte PGSSL=false.
PGSSL=false
